NEWS_PROVIDERS=naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_NEWS_API_URL=https://openapi.naver.com/v1/search/news.json
NAVER_THEME_KEYWORDS=AI,인공지능,생성형AI,GPT,LLM,챗GPT,머신러닝,딥러닝
NAVER_NEWS_DISPLAY=100
NAVER_NEWS_SORT=date
NAVER_NEWS_MAX_PAGES=3
NAVER_MAX_WORKERS=8

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=news_topic
KAFKA_ACKS=all
KAFKA_RETRIES=5
KAFKA_MAX_IN_FLIGHT=1
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_MAX_BLOCK_MS=60000
KAFKA_COMPRESSION_TYPE=gzip
SCHEMA_VERSION=v1
STATE_DIR=./runtime/state

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=news_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SPARK_MASTER=local[*]
SPARK_APP_NAME=news-trend-pipeline
SPARK_CHECKPOINT_DIR=./runtime/checkpoints
SPARK_SHUFFLE_PARTITIONS=2
SPARK_STARTING_OFFSETS=latest
KEYWORD_WINDOW_DURATION=10 minutes
RELATION_KEYWORD_LIMIT=8

# 복합명사 후보 자동 추출 (compound_extraction DAG)
COMPOUND_EXTRACTION_WINDOW_DAYS=1
COMPOUND_EXTRACTION_MIN_FREQUENCY=3
COMPOUND_EXTRACTION_MIN_CHAR_LENGTH=4
COMPOUND_EXTRACTION_MAX_MORPHEME_COUNT=4
