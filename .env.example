NEWS_PROVIDERS=naver,rss
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_NEWS_API_URL=https://openapi.naver.com/v1/search/news.json
NAVER_THEME_KEYWORDS=대통령,국회,경제,금리,코스피,사건사고,교육,미국,중국,AI,반도체,문화,연예,축구
NAVER_NEWS_DISPLAY=100
NAVER_NEWS_SORT=date
NAVER_NEWS_MAX_PAGES=3
NAVER_MAX_WORKERS=4
NAVER_PAGE_REQUEST_DELAY_SECONDS=0.75
NAVER_QUERY_STAGGER_SECONDS=0.15
RSS_FEED_CATALOG_PATH=./data/rss_feeds.csv
RSS_REQUEST_TIMEOUT_SECONDS=20
RSS_MAX_WORKERS=4

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=news_topic
KAFKA_ACKS=all
KAFKA_RETRIES=1
KAFKA_MAX_IN_FLIGHT=1
KAFKA_REQUEST_TIMEOUT_MS=10000
KAFKA_MAX_BLOCK_MS=5000
KAFKA_FLUSH_TIMEOUT_SECONDS=10
KAFKA_COMPRESSION_TYPE=gzip
KAFKA_RECOVERY_VERIFY_MAX_WAIT_SECONDS=180
KAFKA_RECOVERY_VERIFY_RETRY_INTERVAL_SECONDS=10
KAFKA_RECOVERY_VERIFY_REQUEST_TIMEOUT_MS=5000
SCHEMA_VERSION=v1
STATE_DIR=./runtime/state

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=news_pipeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SPARK_MASTER=local[*]
SPARK_APP_NAME=news-trend-pipeline
SPARK_CHECKPOINT_DIR=./runtime/checkpoints
SPARK_WORKER_CORES=1
SPARK_WORKER_MEMORY=2G
SPARK_SHUFFLE_PARTITIONS=8
SPARK_STARTING_OFFSETS=latest
SPARK_MAX_OFFSETS_PER_TRIGGER=150
SPARK_PREPROCESS_PARTITIONS=4
SPARK_JDBC_BATCH_SIZE=2000
SPARK_JDBC_NUM_PARTITIONS=2
KEYWORD_WINDOW_DURATION=10 minutes
RELATION_KEYWORD_LIMIT=4

COMPOUND_EXTRACTION_WINDOW_HOURS=2
COMPOUND_EXTRACTION_MIN_FREQUENCY=3
COMPOUND_EXTRACTION_MIN_CHAR_LENGTH=4
COMPOUND_EXTRACTION_MAX_MORPHEME_COUNT=4
DICTIONARY_REFRESH_INTERVAL_SECONDS=60
