NEWS_PROVIDERS=naver
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_NEWS_API_URL=https://openapi.naver.com/v1/search/news.json
# DIRECTION.md — AI/기술 테마 키워드 (병렬 호출 대상, 콤마 구분)
NAVER_THEME_KEYWORDS=AI,인공지능,생성형AI,GPT,LLM,챗GPT,머신러닝,딥러닝
NAVER_NEWS_DISPLAY=100
NAVER_NEWS_SORT=date
NAVER_NEWS_MAX_PAGES=3
# 병렬 호출 시 최대 워커 수 (키워드 수보다 크면 키워드 수로 클램프)
NAVER_MAX_WORKERS=8
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=news_topic
KAFKA_ACKS=all
KAFKA_RETRIES=5
KAFKA_MAX_IN_FLIGHT=1
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_MAX_BLOCK_MS=60000
KAFKA_COMPRESSION_TYPE=gzip
SCHEMA_VERSION=v1
STATE_DIR=./runtime/state
