.env
.env.*
!.env.example

.venv/
.venv-airflow/
.pylibs/
.spark-pydeps/

.vscode/
__pycache__/
*.pyc
*.pyo

tmp/

# runtime outputs (state, logs) — keep directory shell via .gitkeep
runtime/state/*
!runtime/state/.gitkeep
runtime/logs/*
!runtime/logs/.gitkeep
runtime/checkpoints/*
!runtime/checkpoints/.gitkeep
runtime/spark-events/*
!runtime/spark-events/.gitkeep

# packaging
build/
dist/
*.egg-info/

frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo

.claude/settings.local.json
.claude/worktrees/
