FROM node:20-alpine AS build

WORKDIR /app

COPY src/dashboard/package.json src/dashboard/package-lock.json src/dashboard/tsconfig.json src/dashboard/tsconfig.app.json src/dashboard/vite.config.ts ./
RUN npm install

COPY src/dashboard/index.html ./index.html
COPY src/dashboard/src ./src

RUN npm run build

FROM nginx:1.27-alpine

COPY infra/frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
